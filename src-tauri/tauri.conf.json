{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skylark",
  "version": "../package.json",
  "identifier": "com.radium.skylark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run prepare-installer && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skylark",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 540,
        "decorations": true,
        "transparent": false,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "devtools": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-gpu --disable-gpu-compositing --disable-software-rasterizer"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/rule-sets/geoip-cn.srs",
      "resources/rule-sets/geosite-cn.srs"
    ],
    "externalBin": [
      "binaries/sing-box"
    ],
    "publisher": "Radium",
    "shortDescription": "基于 sing-box 的跨平台代理客户端",
    "longDescription": "一款基于 sing-box 内核的桌面代理客户端，支持 Shadowsocks、VMess、Trojan、Hysteria2 等主流协议。",
    "copyright": "Copyright © 2024 Radium",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp"
      }
    },
    "macOS": {
      "dmg": {
        "background": "installer/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 200 },
        "applicationFolderPosition": { "x": 480, "y": 200 }
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
