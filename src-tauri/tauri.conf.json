{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sing-box",
  "version": "../package.json",
  "identifier": "com.radium.sing-box",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sing-box",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 540,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "publisher": "Radium",
    "shortDescription": "基于 sing-box 的 Windows 代理客户端",
    "copyright": "Copyright © 2024 Radium",
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
